-- Remove All Grass Functions
local function removeTerrainDecoration()
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(Workspace.Terrain, "Decoration", false)
        end
    end)
end

local function removeGrassModels()
    local grassNames = {
        "grass",
        "flower",
        "bush",
        "shrub",
        "weed",
        "fern",
        "moss",
        "leaves",
        "leaf",
        "plant",
        "vegetation"
    }
    
    local function SearchAndDestroy(parent)
        for _, child in pairs(parent:GetChildren()) do
            if child:IsA("Model") or child:IsA("Part") or child:IsA("MeshPart") then
                local childNameLower = string.lower(child.Name)
                for _, grassName in pairs(grassNames) do
                    if string.find(childNameLower, grassName) then
                        child:Destroy()
                        break
                    end
                end
                
                if child:IsA("Part") or child:IsA("MeshPart") then
                    if (child.Material == Enum.Material.Grass or 
                        child.Material == Enum.Material.LeafyGrass or
                        child.Material == Enum.Material.Pebble) and
                       child.Size.Y < 5 and 
                       child.CanCollide == false then
                        child:Destroy()
                    end
                end
            end
            
            if child:IsA("Folder") or child:IsA("Model") then
                SearchAndDestroy(child)
            end
        end
    end
    
    SearchAndDestroy(Workspace)
end

local function toggleRemoveAllGrass()
    GrassRemoverConfig.Enabled = not GrassRemoverConfig.Enabled
    
    if GrassRemoverConfig.Enabled and not GrassRemoverConfig.RemovedGrass then
        removeTerrainDecoration()
        removeGrassModels()
        GrassRemoverConfig.RemovedGrass = true
    end
end

local function createAimFovCircle()
    if AimFovConfig.Circle or AimFovConfig.CircleOutline then
        return
    end
    
    pcall(function()
        local circleOutline = Drawing.new("Circle")
        circleOutline.Color = Color3.new(0, 0, 0)
        circleOutline.Thickness = 3
        circleOutline.NumSides = 60
        circleOutline.Filled = false
        circleOutline.Visible = false
        circleOutline.Transparency = 1
        AimFovConfig.CircleOutline = circleOutline
        
        local circle = Drawing.new("Circle")
