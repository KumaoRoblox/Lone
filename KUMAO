local function updateHighlight(model, esp)
    local teamDot = model:FindFirstChild("TeamDot")
    local shouldHighlight = false

    if teamDot then
        local success, enabled = pcall(function()
            return teamDot.Enabled
        end)
        shouldHighlight = success and enabled == false
    end

    if shouldHighlight then
        if not esp.Highlight or esp.Highlight.Parent ~= model then
            local highlight = Instance.new("Highlight")
            highlight.Name = "TeamDotHighlight"
            highlight.FillTransparency = 1
            highlight.OutlineColor = Color3.new(1, 1, 0)
            highlight.Parent = model
            esp.Highlight = highlight
        else
            esp.Highlight.Enabled = true
        end
    elseif esp.Highlight then
        esp.Highlight:Destroy()
        esp.Highlight = nil
    end
end

local function updateESP()
    local localChar = LocalPlayer.Character
    if not localChar then return end
    
    local localRoot = localChar:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end
    
    for model, esp in pairs(ESPObjects) do
        if not model or not model.Parent then
            removeESP(model)
            continue
        end

        updateHighlight(model, esp)

        -- TeamCheck: Skip players with TeamDot if enabled
        if TeamCheckConfig.Enabled and hasTeamDot(model) then
            hideESP(esp)
            continue
        end
        
        local rootPart = getModelRootPart(model)
        local head = getModelHead(model)
        local humanoid = model:FindFirstChild("Humanoid")
        
        if not rootPart then
            hideESP(esp)
            continue
        end
        
        local distance = (localRoot.Position - rootPart.Position).Magnitude
        if distance > ESP.MaxDistance then
            hideESP(esp)
            continue
        end
        
        local rootScreen = Camera:WorldToViewportPoint(rootPart.Position)
        local headScreen = head and Camera:WorldToViewportPoint(head.Position) or rootScreen
        
        if rootScreen.Z <= 0 then
            hideESP(esp)
            continue
        end
        
        local minX, minY, maxX, maxY = getAccurateModelBounds(model)
        
        if not minX then
            hideESP(esp)
            continue
        end
        
        local angle, isFacingTowards, isFacingAway = getPlayerFacingInfo(model)
        
        if ESP.BoxEnabled and esp.Box and esp.BoxOutline then
            pcall(function()
                local boxWidth = maxX - minX
                local boxHeight = maxY - minY
                
                if boxWidth < 8 then
                    boxWidth = math.max(12, 80 / math.max(distance / 20, 1))
                end
                if boxHeight < 10 then
                    boxHeight = math.max(16, 100 / math.max(distance / 20, 1))
                end
                
                local centerX = (minX + maxX) / 2
                local centerY = (minY + maxY) / 2
                
                local finalX = centerX - boxWidth / 2
                local finalY = centerY - boxHeight / 2
                
                esp.BoxOutline.Size = Vector2.new(boxWidth + 4, boxHeight + 4)
                esp.BoxOutline.Position = Vector2.new(finalX - 2, finalY - 2)
                esp.BoxOutline.Visible = true
                
                esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                esp.Box.Position = Vector2.new(finalX, finalY)
                esp.Box.Visible = true
            end)
        elseif esp.Box and esp.BoxOutline then
            esp.Box.Visible = false
            esp.BoxOutline.Visible = false
        end
        
        if ESP.DistanceEnabled and esp.DistanceText and head then
            pcall(function()
                esp.DistanceText.Text = math.floor(distance) .. "m [" .. model.Name .. "]"
                esp.DistanceText.Position = Vector2.new((minX + maxX) / 2, minY - 20)
                esp.DistanceText.Visible = true
            end)
        elseif esp.DistanceText then
            esp.DistanceText.Visible = false
        end
        
        if ESP.HPEnabled and esp.HPText and humanoid then
            pcall(function()
                local healthPercent = math.floor((humanoid.Health / humanoid.MaxHealth) * 100)
                esp.HPText.Text = healthPercent .. "%"
                esp.HPText.Position = Vector2.new((minX + maxX) / 2, maxY + 5)
                
                if healthPercent > 75 then
                    esp.HPText.Color = Color3.new(0, 1, 0)
                elseif healthPercent > 50 then
                    esp.HPText.Color = Color3.new(1, 1, 0)
                elseif healthPercent > 25 then
                    esp.HPText.Color = Color3.new(1, 0.5, 0)
                else
                    esp.HPText.Color = Color3.new(1, 0, 0)
                end
                
                esp.HPText.Visible = true
            end)
        elseif esp.HPText then
            esp.HPText.Visible = false
        end
        
        if ESP.TracerEnabled and esp.Tracer and esp.TracerOutline then
            pcall(function()
                local fromPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                local toPos = Vector2.new(rootScreen.X, rootScreen.Y)
                
                esp.TracerOutline.From = fromPos
                esp.TracerOutline.To = toPos
                esp.TracerOutline.Visible = true
                
                esp.Tracer.From = fromPos
                esp.Tracer.To = toPos
                esp.Tracer.Visible = true
            end)
        elseif esp.Tracer and esp.TracerOutline then
            esp.Tracer.Visible = false
            esp.TracerOutline.Visible = false
        end
        
        if ESP.DirectionArrowEnabled and esp.DirectionArrow then
            pcall(function()
                local arrowSize = 10
                local arrowOffset = 40
                
                local arrowPos = Vector2.new((minX + maxX) / 2, minY - arrowOffset)
                
                if isFacingTowards then
                    esp.DirectionArrow.PointA = Vector2.new(arrowPos.X, arrowPos.Y - arrowSize)
                    esp.DirectionArrow.PointB = Vector2.new(arrowPos.X - arrowSize/2, arrowPos.Y)
                    esp.DirectionArrow.PointC = Vector2.new(arrowPos.X + arrowSize/2, arrowPos.Y)
                    esp.DirectionArrow.Color = Color3.new(1, 0, 0)
                elseif isFacingAway then
                    esp.DirectionArrow.PointA = Vector2.new(arrowPos.X, arrowPos.Y + arrowSize)
                    esp.DirectionArrow.PointB = Vector2.new(arrowPos.X - arrowSize/2, arrowPos.Y)
                    esp.DirectionArrow.PointC = Vector2.new(arrowPos.X + arrowSize/2, arrowPos.Y)
                    esp.DirectionArrow.Color = Color3.new(0, 1, 0)
                else
                    esp.DirectionArrow.PointA = Vector2.new(arrowPos.X - arrowSize, arrowPos.Y)
                    esp.DirectionArrow.PointB = Vector2.new(arrowPos.X + arrowSize, arrowPos.Y)
                    esp.DirectionArrow.PointC = Vector2.new(arrowPos.X, arrowPos.Y - arrowSize/2)
                    esp.DirectionArrow.Color = Color3.new(1, 1, 0)
                end
                
                esp.DirectionArrow.Visible = true
            end)
        elseif esp.DirectionArrow then
            esp.DirectionArrow.Visible = false
        end
    end
end

local function autoRefresh()
    for _, child in pairs(PlayersFolder:GetChildren()) do
        if isValidModel(child) and not ESPObjects[child] then
            createESP(child)
        end
    end
    
    for model, esp in pairs(ESPObjects) do
        if not model.Parent or not PlayersFolder:FindFirstChild(model.Name) then
            removeESP(model)
        end
    end
end

local function refreshModels()
    for model, esp in pairs(ESPObjects) do
        removeESP(model)
    end
    
    playerTracker = {}
    
    for _, child in pairs(PlayersFolder:GetChildren()) do
        if isValidModel(child) then
            createESP(child)
        end
    end
end

